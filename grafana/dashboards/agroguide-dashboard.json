{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Mixed --",
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Redis Connection Status",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "agroguide_redis_status",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "Offline"
                },
                "1": {
                  "color": "green",
                  "text": "Online"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "agroguide_cache_hit_ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "title": "Blocked Firewall Queries",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "agroguide_blocked_queries_total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "title": "Active BullMQ Workers",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "agroguide_queue_active_jobs",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "title": "AI Latency (Gemini & Vision Service)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(agroguide_gemini_latency_seconds_sum[5m]) / rate(agroguide_gemini_latency_seconds_count[5m])",
          "legendFormat": "Gemini Latency",
          "refId": "A"
        },
        {
          "expr": "rate(vision_detection_latency_seconds_sum[5m]) / rate(vision_detection_latency_seconds_count[5m])",
          "legendFormat": "FastAPI Vision Latency",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "s"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "title": "API Request Durations & Weather Fetch",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum[5m]) / rate(http_request_duration_seconds_count[5m])",
          "legendFormat": "HTTP API Request Latency",
          "refId": "A"
        },
        {
          "expr": "rate(agroguide_weather_latency_seconds_sum[5m]) / rate(agroguide_weather_latency_seconds_count[5m])",
          "legendFormat": "OpenWeather API Fetch Latency",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "s"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "id": 7,
      "title": "System Memory Consumption",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"agroguide-backend\"}",
          "legendFormat": "Express Backend Memory",
          "refId": "A"
        },
        {
          "expr": "process_resident_memory_bytes{job=\"agroguide-vision\"}",
          "legendFormat": "FastAPI Vision Memory",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "id": 8,
      "title": "CPU Usage Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"agroguide-backend\"}[5m])",
          "legendFormat": "Express Backend CPU",
          "refId": "A"
        },
        {
          "expr": "rate(process_cpu_seconds_total{job=\"agroguide-vision\"}[5m])",
          "legendFormat": "FastAPI Vision CPU",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "id": 9,
      "title": "BullMQ Job Progressions",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "agroguide_queue_processed_jobs",
          "legendFormat": "Processed Success",
          "refId": "A"
        },
        {
          "expr": "agroguide_queue_failed_jobs",
          "legendFormat": "Failed Errors",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["agroguide"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "AgroGuide Production Telemetry",
  "weekStart": ""
}
